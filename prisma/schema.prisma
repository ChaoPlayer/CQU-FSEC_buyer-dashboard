generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  password      String? // 加密存储 (仅用于凭证认证)
  role          Role           @default(USER) // USER, ADMIN
  maxLimit      Float?         @default(10000) // 用户可提交的最大金额上限，null 表示无限制
  realName      String?        // 真实姓名
  studentId     String?        // 学号
  group         Group?         // 所属组别
  purchases     Purchase[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Notification {
  id         String    @id @default(cuid())
  type       String
  title      String
  content    String?
  read       Boolean   @default(false)
  user       User      @relation(fields: [userId], references: [id])
  userId     String
  purchase   Purchase? @relation(fields: [purchaseId], references: [id])
  purchaseId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Purchase {
  id               String         @id @default(cuid())
  itemName         String // 物品名称
  category         String? // 采购类型，如电子元件、加工定制件等
  processorContact String? // 加工商联系方式（仅当 category 为加工定制件时填写）
  amount           Float // 总金额
  currency         String         @default("CNY")
  buyLink          String? // 购买链接
  imageUrl         String? // 物品图片 URL
  pdfUrl           String? // 发票 PDF URL
  fileName         String? // 原始文件名
  note             String? // 备注
  status           Status         @default(PENDING) // PENDING, APPROVED, REJECTED
  submittedBy      User           @relation(fields: [userId], references: [id])
  userId           String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  notifications    Notification[]
}

enum Role {
  USER
  ADMIN
}

enum Status {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWAL_REQUESTED
  WITHDRAWN
}

enum Group {
  线路组
  电池组
  电控组
  转向组
  车架组
  悬架组
  车身组
  制动组
  传动组
  综合部
}
