generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  password      String? // 加密存储 (仅用于凭证认证)
  role          Role           @default(USER) // USER, ADMIN
  maxLimit      Float?         @default(10000) // 用户可提交的最大金额上限，null 表示无限制
  approvalLimit Float?         @default(0) // 审批额度
  realName      String?        // 真实姓名
  studentId     String? @unique // 学号
  group         String?        // 所属组别（旧字段，过渡期间保留）
  groupId       String?
  teamGroup     TeamGroup?     @relation(fields: [groupId], references: [id])
  purchases     Purchase[]
  notifications Notification[]
  workSubmissions WorkSubmission[]
  hourRecords   HourRecord[]
  inviteCodes   InviteCode[]   @relation("userInviteCodes")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model TeamGroup {
  id        String   @id @default(uuid())
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
}

model Notification {
  id         String    @id @default(cuid())
  type       String
  title      String
  content    String?
  read       Boolean   @default(false)
  user       User      @relation(fields: [userId], references: [id])
  userId     String
  purchase   Purchase? @relation(fields: [purchaseId], references: [id])
  purchaseId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Purchase {
  id               String         @id @default(cuid())
  itemName         String // 物品名称
  category         String? // 采购类型，如电子元件、加工定制件等
  processorContact String? // 加工商联系方式（仅当 category 为加工定制件时填写）
  amount           Float // 总金额
  currency         String         @default("CNY")
  buyLink          String? // 购买链接
  imageUrl         String? // 物品图片 URL
  pdfUrl           String? // 发票 PDF URL
  fileName         String? // 原始文件名
  note             String? // 备注
  materialCategory String? // 物资类别：车队资产 或 耗材
  hasInvoice       Boolean? // 是否已开发票
  isAdvancedPayment Boolean? // 是否垫付
  advancerName     String? // 垫付人
  status           Status         @default(PENDING) // PENDING, APPROVED, REJECTED
  rejectionReason  String?        // 拒绝理由（仅当 status = REJECTED 时）
  submittedBy      User           @relation(fields: [userId], references: [id])
  userId           String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  notifications    Notification[]
  statusHistory   PurchaseStatusHistory[]
}

enum Role {
  USER
  ADMIN
  GROUP_LEADER
}

enum Status {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWAL_REQUESTED
  WITHDRAWN
}

enum Group {
  线路组
  电池组
  电控组
  转向组
  车架组
  悬架组
  车身组
  制动组
  传动组
  综合部
}

model PurchaseStatusHistory {
  id         String   @id @default(cuid())
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  purchaseId String
  status     Status
  reason     String?  // 状态变更理由，例如拒绝理由
  createdBy  String?  // 操作者用户 ID（可选）
  createdAt  DateTime @default(now())
}

enum WorkSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum HourType {
  ATTENDANCE
  WORK
}

model WorkSubmission {
  id            String               @id @default(cuid())
  title         String               // 工作名称
  description   String?              // 工作内容
  fileUrl       String?              // 文件URL
  fileName      String?              // 原始文件名
  status        WorkSubmissionStatus @default(PENDING)
  approvedHours Float?               // 审批兑换的工时（小时）
  approvedAt    DateTime?            // 审批时间
  approvedBy    String?              // 审批管理员ID
  user          User                 @relation(fields: [userId], references: [id])
  userId        String
  hourRecords   HourRecord[]         // 关联的工时记录
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([userId])
  @@index([status])
}

model HourRecord {
  id             String         @id @default(cuid())
  type           HourType       // 工时类型：ATTENDANCE（考勤）或 WORK（工作）
  hours          Float          // 工时数（小时）
  date           DateTime       @default(now()) // 工时所属日期
  description    String?        // 描述
  user           User           @relation(fields: [userId], references: [id])
  userId         String
  workSubmission WorkSubmission? @relation(fields: [submissionId], references: [id])
  submissionId   String?        // 关联的工作提交ID（仅type=WORK时）
  createdAt      DateTime       @default(now())

  @@index([userId])
  @@index([type])
  @@index([date])
}

model AttendanceSummary {
  id          String   @id @default(cuid())
  employeeNo  String   // 工号
  date        DateTime // 考勤日期（仅日期部分）
  firstPunch  DateTime? // 首次打卡时间
  lastPunch   DateTime? // 末次打卡时间
  totalHours  Float?    // 总工时（小时）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([employeeNo, date])
  @@index([employeeNo])
  @@index([date])
}

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique
  isUsed    Boolean  @default(false)
  usedBy    User?    @relation("userInviteCodes", fields: [usedById], references: [id])
  usedById  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isUsed])
  @@index([code])
}
